# ==============================================
# DIALIST MARKETPLACE API - Environment Variables
# ==============================================
# Copy this file to `.env` and fill in real values
# DO NOT commit this file to version control!
# 
# REQUIRED: All variables without (OPTIONAL) must be set before starting the server
# OPTIONAL: Variables marked as (OPTIONAL) have defaults and are not required

# --------------------------
# Server Configuration
# --------------------------
PORT=5050
NODE_ENV=development

# --------------------------
# Database
# --------------------------
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/market-place?appName=Cluster0

# --------------------------
# Clerk Authentication
# --------------------------
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret

# Feature flag for Clerk mutations (0=disabled, 1=enabled)
FEATURE_CLERK_MUTATIONS=1

# --------------------------
# Finix Payment Processing
# --------------------------
FINIX_USERNAME=your_finix_username
FINIX_PASSWORD=your_finix_password
FINIX_BASE_URL=https://finix.sandbox-payments-api.com
FINIX_VERSION=1.0.0

# Finix Application IDs (get from Finix dashboard -> Applications)
FINIX_US_APPLICATION_ID=APxxxxxxxxxxxxxxxxxxxxxxxxx
FINIX_CA_APPLICATION_ID=APxxxxxxxxxxxxxxxxxxxxxxxxx

# Finix Webhook Authentication
FINIX_WEBHOOK_USERNAME=your_webhook_username
FINIX_WEBHOOK_PASSWORD=your_webhook_password
# Preferred key consumed by config
FINIX_WEBHOOK_SECRET=your_finix_webhook_signing_secret
# Backward-compatible alias
FINIX_WEBHOOK_SIGNING_SECRET=your_finix_webhook_signing_secret

# Base URL for callbacks (use ngrok URL for testing, production URL in prod)
APP_URL=https://your-ngrok-domain.ngrok-free.app

# --------------------------
# GetStream Chat & Messaging
# --------------------------
GETSTREAM_API_KEY=your_getstream_api_key
GETSTREAM_API_SECRET=your_getstream_api_secret
GETSTREAM_APP_ID=your_getstream_app_id

# --------------------------
# Persona Identity Verification
# --------------------------
PERSONA_API_KEY=your_persona_api_key
PERSONA_TEMPLATE_ID=tmpl_xxxxxxxxxxxxxxxxxxxxxxxx
PERSONA_WEBHOOK_SECRET=whsec_your_persona_webhook_secret

# --------------------------
# AWS S3 Storage
# --------------------------
# AWS Credentials
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# S3 Bucket for image storage
AWS_S3_BUCKET=dialist-marketplace-images

# Optional: CloudFront CDN domain for faster image delivery
# AWS_CLOUDFRONT_DOMAIN=d1234567890abc.cloudfront.net

# --------------------------
# Redis (for Background Queue)
# --------------------------
# (OPTIONAL) Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# --------------------------
# Monitoring & Observability
# --------------------------
# (OPTIONAL) Sentry Error Tracking for production error monitoring
SENTRY_DSN=

# (OPTIONAL) Logging Level - debug|info|warn|error (Default: info)
LOG_LEVEL=info

# --------------------------
# Development Tools
# --------------------------
# (OPTIONAL) ngrok auth token for webhook testing (required only if using ngrok for webhooks)
NGROK_AUTH_TOKEN=

# (OPTIONAL) Allowed CORS origins (comma-separated, Default: localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --------------------------
# Testing
# --------------------------
# (OPTIONAL) Silence console output during tests - true|false (Default: false)
SILENT_TESTS=false
