{
  "id": "dialist-local-dev-env",
  "name": "Dialist - Local Dev",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5050",
      "type": "default",
      "enabled": true
    },
    {
      "key": "mockUser",
      "value": "buyer_us_complete",
      "type": "default",
      "enabled": true,
      "description": "Available: buyer_us_complete | merchant_approved | merchant_approved_ca | new_user_us | new_user_ca | merchant_pending | merchant_provisioning | merchant_rejected"
    },
    {
      "key": "authMode",
      "value": "mock",
      "type": "default",
      "enabled": true,
      "description": "Auth mode selector. Set to 'mock' to use x-test-user header (no Clerk needed). Set to 'jwt' to use a real Clerk Bearer token from the 'token' variable."
    },
    {
      "key": "tokenRole",
      "value": "default",
      "type": "default",
      "enabled": true,
      "description": "When authMode='jwt', controls which token to use: 'default' (uses 'token'), 'buyer' (uses 'buyerToken'), or 'seller' (uses 'sellerToken')"
    },
    {
      "key": "token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Clerk JWT (session token). Required when authMode = 'jwt'. Paste your token here — get it from Clerk Dashboard > Users > [user] > Sessions, or from the browser DevTools Network tab (look for the Authorization header on any Dialist request)."
    },
    {
      "key": "buyerToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Buyer Clerk JWT Token (valid ~12 hours). Get from Clerk Dashboard or DevTools after logging in as buyer. Set authMode='jwt' and use this token for buyer-specific requests."
    },
    {
      "key": "sellerToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Seller Clerk JWT Token (valid ~12 hours). Get from Clerk Dashboard or DevTools after logging in as seller. Set authMode='jwt' and use this token for seller-specific requests."
    },
    {
      "key": "listingId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set when you POST /networks/listings"
    },
    {
